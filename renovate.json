{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": ["^Containerfile$"],
      "matchStrings": ["ARG NODE_VERSION=(?<currentValue>[\\d.]+)"],
      "depNameTemplate": "node",
      "datasourceTemplate": "node-version"
    }
  ],
  "packageRules": [
    {
      "matchDepNames": ["debian"],
      "enabled": false
    }
  ]
}
